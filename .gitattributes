# Normalise all text files to LF on checkin and checkout.
# This prevents CRLF/LF noise in diffs when contributors work on Windows.
* text=auto eol=lf

# Explicitly declare common source formats
*.py    text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.sh    text eol=lf
*.js    text eol=lf
*.ts    text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
*.toml  text eol=lf

# Binary files — never touch line endings
*.pkl   binary
*.pth   binary
*.pt    binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.npy   binary
*.npz   binary
