# Ignore everything
*

# But exclude these specific file types
!*.py
!*.pdf
!*.md
!*.txt
!*.pth
!*.JPG
!*.log

# Allow specific directories and their contents
!agentic_cascade_system/
!agentic_cascade_system/**
!checkpoints/
!checkpoints/**
!images/
!images/**
!cascade_prediction/
!cascade_prediction/**

# And exclude the .gitignore file itself
!.gitignore

# Ignore Python cache directories (even in allowed directories)
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
.Python
**/*.so
**/*.egg
**/*.egg-info/
**/dist/
**/build/